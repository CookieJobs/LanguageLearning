# Server
API_PORT=5500

# MongoDB
MONGO_URL=mongodb://localhost:27017/linguacraft

# Redis
REDIS_URL=redis://localhost:6379

# JWT (IMPORTANT: Change this in production!)
JWT_SECRET=change_me_to_a_random_string

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# SMTP (for sending verification codes)
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_authorization_code
SMTP_FROM=your_email@qq.com
